@page "/app-services"

<PageTitle>App Services — Advanced Cloud Self Service</PageTitle>

<div class="d-flex justify-content-between align-items-baseline mb-3">
    <span class="page-title-main">App Services</span>
</div>

<div class="alert alert-info mb-3" role="alert">
    Restart operations require appropriate Azure RBAC permissions. Actions are logged to the audit trail.
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>App Service</th>
                    <th>Environment</th>
                    <th>Resource Group</th>
                    <th>State</th>
                    <th style="width:130px;text-align:center;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="5" class="text-center py-4" style="color:var(--text-color);opacity:0.5;font-size:0.9rem;">
                        No app services configured yet. Connect to Azure Resource Management API to populate.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
