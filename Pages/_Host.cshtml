@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace CloudSelfService.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link href="css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="CloudSelfService.styles.css" rel="stylesheet" asp-append-version="true" />
    <link rel="icon" type="image/png" href="images/advanced-logo-a.png"/>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    @* Custom Blazor SignalR reconnect overlay — see wwwroot/css/site.css for state-class styling. *@
    <div id="components-reconnect-modal" class="reconnect-modal">
        <div class="reconnect-modal-card">
            <div class="reconnect-modal-spinner" aria-hidden="true"></div>
            <p class="reconnect-modal-text reconnect-modal-text--show">Rejoining the server&hellip;</p>
            <p class="reconnect-modal-text reconnect-modal-text--failed">Reconnection failed. Try <a href="" class="reconnect-modal-link">reloading</a> the page.</p>
            <p class="reconnect-modal-text reconnect-modal-text--rejected">Could not reconnect to the server. <a href="" class="reconnect-modal-link">Reload</a> the page to restore functionality.</p>
            <p class="reconnect-modal-text reconnect-modal-text--reloading">Restoring your session&hellip;</p>
        </div>
    </div>

    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="js/theme-manager.js" asp-append-version="true"></script>
    <script src="js/session-guard.js" asp-append-version="true"></script>
    <script src="_framework/blazor.server.js" autostart="false"></script>
    <script>
        Blazor.start({
            configureSignalR: function (builder) {
                builder.withUrl('/_blazor', { transport: 4 }); // 4 = LongPolling
            },
            circuit: {
                reconnectionOptions: {
                    maxRetries: 8,
                    retryIntervalMilliseconds: Array.prototype.at.bind(
                        [0, 2000, 5000, 10000, 15000, 20000, 30000, 45000, 60000])
                }
            }
        }).then(function () {
            window.SessionGuard.initReconnectRecovery();
        });
    </script>
</body>
</html>
